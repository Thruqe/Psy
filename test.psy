IMPORT _NETWORK[HTTP_GET, HTTP_POST, HTTP_PUT, HTTP_DELETE, URL_ENCODE, URL_DECODE]
IMPORT _JSON[JSON_PARSE, JSON_STRINGIFY, JSON_GET, JSON_KEYS]

START
    OUTPUT "========================================="
    OUTPUT "   PSY NETWORK & JSON MODULE"
    OUTPUT "========================================="
    OUTPUT ""
    
    // Test 1: Basic GET request
    OUTPUT "1. HTTP GET Request"
    OUTPUT "-------------------"
    response = HTTP_GET("http://httpbin.org/get")
    status = response[0]
    headers = response[1]
    body = response[2]
    
    OUTPUT "Status Code: "
    OUTPUT status
    OUTPUT ""
    
    OUTPUT "Response Headers:"
    OUTPUT headers
    OUTPUT ""
    
    // Parse the JSON body
    parsed = JSON_PARSE(body)
    OUTPUT "Parsed JSON:"
    OUTPUT parsed
    OUTPUT ""
    
    // Get specific values from JSON
    origin = JSON_GET(body, "origin")
    OUTPUT "Your IP Address: "
    OUTPUT origin
    OUTPUT ""
    
    // Test 2: URL Encoding
    OUTPUT "2. URL Encoding/Decoding"
    OUTPUT "-----------------------"
    original = "Hello World! This is Psy Network Module"
    encoded = URL_ENCODE(original)
    decoded = URL_DECODE(encoded)
    
    OUTPUT "Original: " + original
    OUTPUT "Encoded:  " + encoded
    OUTPUT "Decoded:  " + decoded
    OUTPUT ""
    
    // Test 3: POST Request with custom data
    OUTPUT "3. HTTP POST Request"
    OUTPUT "--------------------"
    
    // Create JSON-like data
    userData = JSON_STRINGIFY("[name: Psy User, version: 1.0, language: Psy]")
    OUTPUT "Sending data: " + userData
    
    response = HTTP_POST("http://httpbin.org/post", userData)
    status = response[0]
    body = response[2]
    
    OUTPUT "Status: "
    OUTPUT status
    OUTPUT ""
    
    parsed = JSON_PARSE(body)
    OUTPUT "Response:"
    OUTPUT parsed
    OUTPUT ""
    
    // Test 4: PUT Request
    OUTPUT "4. HTTP PUT Request"
    OUTPUT "-------------------"
    updateData = JSON_STRINGIFY("[status: updated, timestamp: 1234567890]")
    response = HTTP_PUT("http://httpbin.org/put", updateData)
    status = response[0]
    body = response[2]
    
    OUTPUT "Status: "
    OUTPUT status
    OUTPUT "Response:"
    OUTPUT JSON_PARSE(body)
    OUTPUT ""
    
    // Test 5: DELETE Request
    OUTPUT "5. HTTP DELETE Request"
    OUTPUT "----------------------"
    response = HTTP_DELETE("http://httpbin.org/delete")
    status = response[0]
    body = response[2]
    
    OUTPUT "Status: "
    OUTPUT status
    OUTPUT "Response:"
    OUTPUT JSON_PARSE(body)
    OUTPUT ""
    
    // Test 6: Working with JSON responses
    OUTPUT "6. JSON Manipulation"
    OUTPUT "--------------------"
    
    // Get headers from a response
    response = HTTP_GET("http://httpbin.org/headers")
    body = response[2]
    parsed = JSON_PARSE(body)
    
    OUTPUT "Response headers object:"
    OUTPUT parsed
    OUTPUT ""
    
    keys = JSON_KEYS(body)
    OUTPUT "Top-level keys: "
    OUTPUT keys
    OUTPUT ""
    
    // Test 7: Error handling
    OUTPUT "7. Error Handling"
    OUTPUT "------------------"
    
    // Try invalid URL
    response = HTTP_GET("http://invalid.domain.that.does.not.exist")
    status = response[0]
    
    IF status = 0 THEN
        OUTPUT "Expected error with invalid domain"
        OUTPUT "Status: "
        OUTPUT status
    ELSE
        OUTPUT "Unexpected success with invalid domain"
        OUTPUT "Status: "
        OUTPUT status
    ENDIF
    OUTPUT ""
    
    // Test 8: Building complex requests
    OUTPUT "8. Building Complex Requests"
    OUTPUT "-----------------------------"
    
    // Create a user object
    username = "PsyDev"
    email = "dev@psylang.org"
    
    userJson = "{"
    userJson = userJson + "username: " + username + ", "
    userJson = userJson + "email: " + email + ", "
    userJson = userJson + "active: true"
    userJson = userJson + "}"
    
    OUTPUT "Constructed JSON:"
    OUTPUT userJson
    OUTPUT ""
    
    // Send it
    response = HTTP_POST("http://httpbin.org/post", userJson)
    OUTPUT "POST Response Status: "
    OUTPUT response[0]
    OUTPUT ""
END