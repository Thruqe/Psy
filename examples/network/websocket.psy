IMPORT _NETWORK[WS_CONNECT, WS_SEND, WS_RECEIVE, WS_CLOSE]

START
    OUTPUT "========================================="

    OUTPUT "   PSY WEBSOCKET TEST"

    OUTPUT "========================================="

    OUTPUT ""

    OUTPUT "Connecting to echo.websocket.org..."

    connId = WS_CONNECT("wss://echo.websocket.org")

    OUTPUT "Connected! Connection ID: "

    OUTPUT connId

    OUTPUT ""

    OUTPUT "Sending: Hello from Psy!"

    WS_SEND(connId, "Hello from Psy!")

    reply = WS_RECEIVE(connId)

    OUTPUT "Echo received: "

    OUTPUT reply

    OUTPUT ""

    OUTPUT "Sending: {\"type\": \"ping\", \"id\": 1}"

    WS_SEND(connId, "{\"type\": \"ping\", \"id\": 1}")

    reply2 = WS_RECEIVE(connId)

    OUTPUT "Echo received: "

    OUTPUT reply2

    OUTPUT ""

    OUTPUT "Sending: Goodbye!"

    WS_SEND(connId, "Goodbye!")

    reply3 = WS_RECEIVE(connId)

    OUTPUT "Echo received: "

    OUTPUT reply3

    OUTPUT ""

    WS_CLOSE(connId)

    OUTPUT "Connection closed."

    OUTPUT ""

    OUTPUT "WebSocket test complete!"
END
