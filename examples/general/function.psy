START
    FUNCTION sum(n)
        IF n == 1 THEN
            RETURN 1
        ELSE
            RETURN n + sum(n - 1)
        ENDIF
    ENDFUNCTION

    result = sum(4)

    OUTPUT result

    FUNCTION subtract(a, b)
        RETURN a - b
    ENDFUNCTION

    FUNCTION stringlike(data String)
        RETURN "Ypp:" + data
    ENDFUNCTION

    OUTPUT stringlike("data")
END
