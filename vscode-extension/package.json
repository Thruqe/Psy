{
	"name": "psy-lsp",
	"displayName": "Psy LSP",
	"description": "Psy Language Server Protocol extension",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.103.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:psy"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "psy",
				"aliases": [
					"Psy",
					"psy"
				],
				"extensions": [
					".psy"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "psy",
				"scopeName": "source.psy",
				"path": "./syntaxes/psy.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"@types/vscode": "^1.103.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"vscode-languageclient": "^10.0.0-next.22"
	}
}
