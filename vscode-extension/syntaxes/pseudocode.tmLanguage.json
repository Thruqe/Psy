{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Pseudocode",
    "scopeName": "source.psc",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#variables"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.psc",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.psc",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.psc",
                    "match": "\\b(IF|ELSE|THEN|ENDIF|FOR|TO|ENDFOR|WHILE|ENDWHILE|REPEAT|UNTIL|CASE|ENDCASE|BREAK|CONTINUE|RETURN)\\b"
                },
                {
                    "name": "keyword.other.psc",
                    "match": "\\b(START|END|INPUT|OUTPUT|PRINT|READ|WRITE|OPEN|CLOSE)\\b"
                },
                {
                    "name": "keyword.operator.logical.psc",
                    "match": "\\b(AND|OR|NOT|XOR)\\b"
                },
                {
                    "name": "storage.type.psc",
                    "match": "\\b(INTEGER|REAL|STRING|BOOLEAN|CHAR|ARRAY|LIST|DICTIONARY|MAP|SET|FUNCTION|PROCEDURE)\\b"
                },
                {
                    "name": "constant.language.psc",
                    "match": "\\b(TRUE|FALSE|NULL|NIL|UNDEFINED)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.psc",
                    "match": "[+\\-*/%^]"
                },
                {
                    "name": "keyword.operator.comparison.psc",
                    "match": "(=|==|!=|<>|<|>|<=|>=)"
                },
                {
                    "name": "keyword.operator.assignment.psc",
                    "match": "="
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.psc",
                    "match": "\\b\\d+\\b"
                },
                {
                    "name": "constant.numeric.float.psc",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.hex.psc",
                    "match": "\\b0x[0-9A-Fa-f]+\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.psc",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.psc",
                            "match": "\\\\(n|t|r|\\\\|\"|')"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.psc",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.psc",
                            "match": "\\\\(n|t|r|\\\\|\"|')"
                        }
                    ]
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "support.function.builtin.psc",
                    "match": "\\b(INPUT|OUTPUT|PRINT|READ|WRITE|OPEN|CLOSE|LEN|LENGTH|SUBSTRING|MID|LEFT|RIGHT|TRIM|UPPER|LOWER|ASC|CHR|VAL|STR|RANDOM|INT|ABS|SQRT|SIN|COS|TAN|LOG|EXP)\\b"
                },
                {
                    "name": "entity.name.function.psc",
                    "match": "(?<=FUNCTION\\s+)[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "name": "variable.other.psc",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    },
    "scopeName": "source.psc"
}